NODE_ENV="development"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/opkit"
REDIS_URL="redis://localhost:6379"
PORT=4000
CLIENT_ORIGIN="http://localhost:3000"
JWT_ACCESS_SECRET="replace-with-a-random-access-secret-at-least-32-chars"
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_SECRET="replace-with-a-random-refresh-secret-at-least-32-chars"
JWT_REFRESH_TTL_SECONDS=604800
COOKIE_NAME="refresh_token"
COOKIE_DOMAIN=""
COOKIE_SECURE=false
BCRYPT_ROUNDS=12
